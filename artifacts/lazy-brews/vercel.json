{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://lazy-brews-api.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  {
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm build",
  "outputDirectory": "dist",
}
  "installCommand": "pnpm install"
}
